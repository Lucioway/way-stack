# DeployAgent Configuration
# Copy to .env and fill in values

# GitHub (gh CLI handles auth, but you can override)
# GITHUB_TOKEN=ghp_...

# Vercel (vercel CLI handles auth, but you can override)
# VERCEL_TOKEN=...

# Clerk (auto-provisioned via Vercel Marketplace)
# CLERK_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
